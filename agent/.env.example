# Required for the agent to call the LLM — when routing direct to Anthropic
# (i.e. no `PYDANTIC_AI_GATEWAY_API_KEY` set). If the gateway is wired, this
# isn't used.
ANTHROPIC_API_KEY=

# Routes the agent through the Pydantic AI Gateway when set. Region + base URL
# are inferred from the key (`pylf_v2_us_...` → `https://gateway-us.pydantic.dev/proxy`).
# Mint from Logfire → Gateway → Project keys.
PYDANTIC_AI_GATEWAY_API_KEY=

# Required for Logfire instrumentation (traces, scrubbing).
# Leave blank to run with local-only logging.
LOGFIRE_TOKEN=

# Required for managed-variables surface (prompts / configurable bounds).
# Mint at: <project> -> Settings -> API keys, with scope
# `project:read_variables` (+ `project:write_variables` to run
# `scripts/push_variables.py`). Without this, `logfire.var(...)` falls
# back to the code-side default forever — no remote tuning.
LOGFIRE_API_KEY=

# Whether prompts / completions / tool args / tool results reach Logfire.
# Defaults to true (you can see your conversation in traces). Set to "false"
# for prod / shared environments to scrub content from traces.
LOGFIRE_INCLUDE_CONTENT=true

# Optional - the canonical rubric & contract source.
# Defaults to ../summerchild-llm (sibling repo).
SUMMERCHILD_RUBRIC_DIR=

# Optional - override the baseline model. Default: claude-sonnet-4-6
SUMMERCHILD_MODEL=

# Optional - shift-budget fraction (default 0.25), soft question target
# (default 15), and hard question cap (default 30). Normally resolved from
# Logfire managed variables; these env vars are a local-dev escape hatch.
SUMMERCHILD_SHIFT_BUDGET_FRACTION=
SUMMERCHILD_SOFT_QUESTION_TARGET=
SUMMERCHILD_HARD_QUESTION_CAP=
